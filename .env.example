# ─────────────────────────────────────────────────────────────────────────────
# Gangatirtham — environment. Copy to `.env.local` and fill in.
# M0/M1 only require the Sanity block + the site URL. The rest land in M6.
# ─────────────────────────────────────────────────────────────────────────────

# Sanity (editorial CMS). Create a project at https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Read token (Viewer) for server-side fetches of draft/private content.
SANITY_API_READ_TOKEN=
# Write token (Editor) — used ONLY by the seed script. Never expose to the client.
SANITY_API_WRITE_TOKEN=
# Shared secret for the Sanity → /api/revalidate webhook (M2).
SANITY_REVALIDATE_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Transactional / integrations (M6 — not required for M0/M1) ───────────────
# DATABASE_URL=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# RESEND_API_KEY=
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# SENTRY_DSN=
